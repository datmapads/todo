# Mẫu cấu hình — copy file này thành ".env" rồi điền giá trị thật.
#   cp .env.example .env
#
# File ".env" thật sự (chứa mật khẩu) đã được thêm vào .gitignore
# và KHÔNG được đưa lên hệ thống quản lý phiên bản (Git/GitHub...).

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=your_password_here
DB_NAME=todo_db
